{
  "name": "claude-channel-agentpost",
  "version": "0.0.6",
  "description": "E2E-encrypted email channel for Claude Code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": "./dist/server.js",
  "scripts": {
    "build": "bun build server.ts --target=bun --outdir=dist --external libsodium-wrappers-sumo",
    "start": "bun install --no-summary && bun dist/server.js",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "libsodium-wrappers-sumo": "^0.7.15",
    "postal-mime": "^2.4.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/turndown": "^5.0.6"
  }
}
